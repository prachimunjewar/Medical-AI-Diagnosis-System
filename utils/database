import os
import pandas as pd

def get_client():
    try:
        import streamlit as st
        from supabase import create_client

        # try streamlit secrets first
        try:
            url = st.secrets["SUPABASE_URL"]
            key = st.secrets["SUPABASE_KEY"]
        except Exception:
            url = os.environ.get("SUPABASE_URL", "")
            key = os.environ.get("SUPABASE_KEY", "")

        if not url or not key:
            return None

        return create_client(url, key)
    except Exception:
        return None


def init_db():
    pass  # table already created in Supabase dashboard


def save_patient(patient_data: dict, ml_result: dict, tumor_result: dict = None):
    try:
        client = get_client()
        if not client:
            return
        record = {
            "age": patient_data.get("Age"),
            "glucose": patient_data.get("Glucose"),
            "blood_pressure": patient_data.get("BloodPressure"),
            "bmi": patient_data.get("BMI"),
            "insulin": patient_data.get("Insulin"),
            "skin_thickness": patient_data.get("SkinThickness"),
            "pregnancies": patient_data.get("Pregnancies"),
            "diabetes_pedigree": patient_data.get("DiabetesPedigreeFunction"),
            "model_used": ml_result.get("model"),
            "prediction": ml_result.get("label"),
            "risk_probability": ml_result.get("probability"),
            "brain_tumor_result": tumor_result.get("label") if tumor_result else None,
            "brain_tumor_confidence": tumor_result.get("confidence") if tumor_result else None,
        }
        client.table("patients").insert(record).execute()
    except Exception:
        pass


def get_all_patients():
    try:
        client = get_client()
        if not client:
            return pd.DataFrame()
        response = client.table("patients").select("*").order("id", desc=True).execute()
        return pd.DataFrame(response.data)
    except Exception:
        return pd.DataFrame()


def get_filtered_patients(outcome=None, age_min=None, age_max=None, glucose_min=None, glucose_max=None):
    try:
        client = get_client()
        if not client:
            return pd.DataFrame()
        query = client.table("patients").select("*")
        if outcome and outcome != "All":
            query = query.eq("prediction", outcome)
        if age_min is not None:
            query = query.gte("age", age_min)
        if age_max is not None:
            query = query.lte("age", age_max)
        if glucose_min is not None:
            query = query.gte("glucose", glucose_min)
        if glucose_max is not None:
            query = query.lte("glucose", glucose_max)
        response = query.order("id", desc=True).execute()
        return pd.DataFrame(response.data)
    except Exception:
        return pd.DataFrame()


def get_summary_stats():
    try:
        client = get_client()
        if not client:
            return {"total": 0, "diabetic": 0, "non_diabetic": 0,
                    "avg_glucose": 0, "avg_age": 0, "avg_bmi": 0, "mri_scans": 0}
        response = client.table("patients").select("*").execute()
        df = pd.DataFrame(response.data)
        if df.empty:
            return {"total": 0, "diabetic": 0, "non_diabetic": 0,
                    "avg_glucose": 0, "avg_age": 0, "avg_bmi": 0, "mri_scans": 0}
        return {
            "total": len(df),
            "diabetic": len(df[df["prediction"] == "Diabetic"]),
            "non_diabetic": len(df[df["prediction"] == "Non-Diabetic"]),
            "avg_glucose": round(df["glucose"].mean(), 1),
            "avg_age": round(df["age"].mean(), 1),
            "avg_bmi": round(df["bmi"].mean(), 1),
            "mri_scans": len(df[df["brain_tumor_result"].notna()]),
        }
    except Exception:
        return {"total": 0, "diabetic": 0, "non_diabetic": 0,
                "avg_glucose": 0, "avg_age": 0, "avg_bmi": 0, "mri_scans": 0}


def delete_patient(patient_id: int):
    try:
        client = get_client()
        if not client:
            return
        client.table("patients").delete().eq("id", patient_id).execute()
    except Exception:
        pass


def clear_all_patients():
    try:
        client = get_client()
        if not client:
            return
        client.table("patients").delete().neq("id", 0).execute()
    except Exception:
        pass
